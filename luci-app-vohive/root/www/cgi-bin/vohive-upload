#!/bin/sh

# VoHive core binary upload CGI script.
# Receives raw file data via HTTP POST body and writes to a temp path
# under /tmp/vohive/upload/ for the upload_core task to install.

UPLOAD_DIR="/tmp/vohive/upload"
UPLOAD_FILE="$UPLOAD_DIR/vohive-core-upload"
MAX_SIZE=$((100 * 1024 * 1024))  # 100 MB

respond() {
	printf 'Content-Type: application/json\r\n\r\n%s\n' "$1"
	exit 0
}

# Only accept POST requests.
[ "${REQUEST_METHOD}" = "POST" ] ||
	respond '{"ok":false,"message":"仅接受 POST 请求"}'

# Basic auth: require a LuCI session cookie to prevent unauthorized uploads.
case "$HTTP_COOKIE" in
	*sysauth*) ;;
	*) respond '{"ok":false,"message":"未授权访问"}' ;;
esac

# Validate Content-Length.
CL="${CONTENT_LENGTH:-0}"
case "$CL" in
	''|*[!0-9]*)
		respond '{"ok":false,"message":"无效的 Content-Length"}'
		;;
esac

[ "$CL" -gt 0 ] ||
	respond '{"ok":false,"message":"上传文件为空"}'

[ "$CL" -le "$MAX_SIZE" ] ||
	respond '{"ok":false,"message":"文件大小超过限制（最大 100 MB）"}'

# Prepare upload directory.
mkdir -p "$UPLOAD_DIR"
rm -f "$UPLOAD_FILE"

# Read exactly $CL bytes from stdin (uhttpd provides body via stdin).
head -c "$CL" > "$UPLOAD_FILE" 2>/dev/null

# Verify the written file size matches Content-Length.
ACTUAL_SIZE=$(wc -c < "$UPLOAD_FILE" 2>/dev/null || echo 0)
case "$ACTUAL_SIZE" in
	''|*[!0-9]*) ACTUAL_SIZE=0 ;;
esac

[ "$ACTUAL_SIZE" = "$CL" ] || {
	rm -f "$UPLOAD_FILE"
	respond "{\"ok\":false,\"message\":\"上传不完整（期望 $CL 字节，实际 $ACTUAL_SIZE 字节）\"}"
}

respond "{\"ok\":true,\"path\":\"$UPLOAD_FILE\",\"size\":$ACTUAL_SIZE}"
